# GeoAI DataHub v2 环境配置示例

# ====================
# 应用基础配置
# ====================

# 应用设置
APP_NAME=GeoAI DataHub v2
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:3000
APP_TIMEZONE=Asia/Shanghai

# 密钥和安全
APP_KEY=base64:your-app-key-here
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRE=7200

# ====================
# 数据库配置
# ====================

# PostgreSQL + PostGIS
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=geoai_datahub
DB_USERNAME=geoai_user
DB_PASSWORD=your-db-password-here

# Redis缓存
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ====================
# 前端配置
# ====================

# Mapbox访问令牌
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token-here
MAPBOX_STYLE=mapbox://styles/mapbox/dark-v11

# 前端开发服务器
VITE_APP_TITLE=GeoAI DataHub v2
VITE_APP_API_URL=http://localhost:8000/api
VITE_APP_MAPBOX_TOKEN=${MAPBOX_ACCESS_TOKEN}

# ====================
# AI服务配置
# ====================

# 阿里云百炼API (深度分析)
BAILIAN_API_KEY=your-bailian-api-key-here
BAILIAN_MODEL=qwen-max
BAILIAN_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1

# TensorFlow Serving
TF_SERVING_HOST=localhost
TF_SERVING_PORT=8501
TF_MODEL_NAME=remote_sensing_model

# ONNX Runtime
ONNX_MODEL_PATH=./models/remote_sensing.onnx

# ====================
# 文件存储配置
# ====================

# MinIO对象存储
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=geoai-data
MINIO_SECURE=false

# 本地文件存储
STORAGE_PATH=./storage/uploads
MAX_UPLOAD_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=tif,tiff,jpg,jpeg,png,shp,geojson,kml,kmz

# ====================
# 第三方服务
# ====================

# 飞书集成
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_BOT_TOKEN=your-feishu-bot-token

# GitHub (论文监控)
GITHUB_TOKEN=your-github-token
GITHUB_REPO_OWNER=your-username
GITHUB_REPO_NAME=geoai-datahub

# 邮件服务
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls

# ====================
# 监控和日志
# ====================

# Sentry错误监控
SENTRY_DSN=your-sentry-dsn-here

# Prometheus监控
PROMETHEUS_PORT=9090

# 日志级别
LOG_LEVEL=debug
LOG_CHANNEL=stack
LOG_SLACK_WEBHOOK_URL=

# ====================
# 开发工具
# ====================

# Docker开发环境
DOCKER_COMPOSE_PROFILE=development
DOCKER_NETWORK=geoai-network

# 测试配置
TEST_DATABASE=geoai_datahub_test
TEST_REDIS_DB=1

# ====================
# 功能开关
# ====================

# 模块启用状态
FEATURE_DATA_MANAGEMENT=true
FEATURE_DATA_PROCESSING=true
FEATURE_DATA_ANALYSIS=true
FEATURE_AI_SEARCH=true

# AI功能开关
FEATURE_AI_PREDICTION=true
FEATURE_IMAGE_RECOGNITION=true
FEATURE_NLP_SEARCH=true

# 第三方集成开关
FEATURE_FEISHU_NOTIFICATION=true
FEATURE_EMAIL_NOTIFICATION=false
FEATURE_GITHUB_SYNC=true

# ====================
# 性能配置
# ====================

# 并发处理
MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT=3600  # 秒

# 缓存配置
CACHE_TTL=3600  # 秒
QUERY_CACHE_ENABLED=true

# 内存限制
MEMORY_LIMIT=4096  # MB
PROCESS_TIMEOUT=300  # 秒

# ====================
# 地理处理配置
# ====================

# GDAL配置
GDAL_CACHE_MAX=512
GDAL_DISABLE_READDIR_ON_OPEN=EMPTY_DIR

# 坐标系统
DEFAULT_CRS=EPSG:4326
PROJECTION_CRS=EPSG:3857

# 空间索引
SPATIAL_INDEX_GRID_SIZE=medium
SPATIAL_INDEX_BUFFER=0.01

# ====================
# 使用说明
# ====================

# 1. 复制此文件为 .env
# cp .env.example .env

# 2. 根据实际环境修改配置值
# 3. 开发环境可以使用默认值，生产环境必须修改安全相关配置
# 4. 敏感信息(密码、密钥)必须保密，不要提交到版本控制

# 注意：所有以"your-"开头的值都需要替换为实际值